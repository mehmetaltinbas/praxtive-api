{
    "name": "extralyz-api-nestjs",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "dotenv -e .dev.local.env -- nest start",
        "dev": "dotenv -e .dev.local.env -- nest start --watch",
        "debug": "dotenv -e .dev.local.env -- nest start --debug --watch",
        "start:prod": "dotenv -e .dev.local.env -- node dist/src/main",
        "lint": "eslint \"{src,test}/**/*.ts\" --fix",
        "db:dev:up": "docker compose up dev-db -d && sleep 2 && docker exec extralyz-dev-db mongosh --eval \"try { rs.status(); } catch(e) { rs.initiate(); }\"",
        "db:dev:down": "docker compose down dev-db",
        "db:dev:restart": "npm run db:dev:down && npm run db:dev:up",
        "db:dev:rs:initiate": "docker exec extralyz-dev-db mongosh --eval \"rs.initiate()\"",
        "db:dev:rs:status": "docker exec extralyz-dev-db mongosh --eval \"rs.status()\"",
        "db:dev:rs:reconfig": "docker exec extralyz-dev-db mongosh --eval \"rs.reconfig({_id: 'rs0', members: [{_id: 0, host: 'localhost:27017'}]}, {force: true})\"",
        "db:test:up": "docker compose up test-db -d && sleep 2 && docker exec extralyz-test-db mongosh --eval \"try { rs.status(); } catch(e) { rs.initiate(); }\"",
        "db:test:down": "docker compose down test-db",
        "db:test:restart": "npm run db:test:down && npm run db:test:up",
        "db:test:rs:status": "docker exec extralyz-test-db mongosh --eval \"rs.status()\"",
        "db:test:rs:initiate": "docker exec extralyz-test-db mongosh --eval \"rs.initiate()\"",
        "db:migrate:one-time-script": "dotenv -e .dev.local.env -- ts-node scripts/",
        "test": "dotenv -e .test.local.env -- jest",
        "test:watch": "dotenv -e .test.local.env -- jest --watch",
        "test:cov": "dotenv -e .test.local.env -- jest --coverage",
        "test:debug": "dotenv -e .test.local.env -- node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "pretest:e2e": "npm run db:test:restart",
        "test:e2e": "dotenv -e .test.local.env -- jest --config ./test/jest-e2e.json",
        "docker:build": "docker build -t altnbsmehmet/extralyz-api .",
        "docker:push": "docker push altnbsmehmet/extralyz-api",
        "docker:deploy": "npm run docker:build && npm run docker:push"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.0.1",
        "@nestjs/event-emitter": "^3.0.1",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/platform-socket.io": "^11.1.6",
        "@nestjs/schedule": "^6.0.1",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/websockets": "^11.1.6",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "cookie-parser": "^1.4.7",
        "iyzipay": "^2.0.65",
        "mammoth": "^1.9.1",
        "mongoose": "^8.16.1",
        "openai": "^5.11.0",
        "pdf-lib": "^1.17.1",
        "pdf-parse": "^1.1.1",
        "pdfjs-dist": "^5.4.149",
        "pdfkit": "^0.17.2",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "socket.io": "^4.8.1",
        "stripe": "^20.4.1"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@swc/cli": "^0.6.0",
        "@swc/core": "^1.10.7",
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.9",
        "@types/express": "^5.0.0",
        "@types/iyzipay": "^2.0.3",
        "@types/jest": "^29.5.14",
        "@types/multer": "^2.0.0",
        "@types/node": "^22.10.7",
        "@types/pdf-parse": "^1.1.5",
        "@types/pdfkit": "^0.17.5",
        "@types/supertest": "^6.0.2",
        "dotenv-cli": "^8.0.0",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "globals": "^16.0.0",
        "jest": "^29.7.0",
        "prettier": "^3.4.2",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
